# Пример файла с переменными окружения для Nuvio
# Для headless/systemd-сценария рекомендуемый путь: .secrets/.env
# Legacy-вариант .env в корне всё ещё поддерживается как fallback

# =============================================================================
# ОБЯЗАТЕЛЬНЫЕ ПЕРЕМЕННЫЕ
# =============================================================================

# Токен Telegram бота (получить у @BotFather)
# Пример: TELEGRAM_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_TOKEN=

# API ключ для Gokapi сервиса (опционально, нужен только для файлов больше лимита Telegram)
# Получить в админ-панели Gokapi
GOKAPI_API_KEY=

# URL для Gokapi API (опционально, включая /api/ в конце)
# Пример: GOKAPI_BASE_URL=https://your-gokapi-domain.com/api/
GOKAPI_BASE_URL=

# ID администраторов бота (через запятую)
# Эти пользователи смогут обновлять файлы cookies и управлять кэшем
# Получить ID можно у бота @userinfobot
# Пример: ADMIN_IDS=123456789,987654321
ADMIN_IDS=

# =============================================================================
# WEB UI (аналитический дашборд)
# =============================================================================

# Логин и пароль для доступа к веб-дашборду
# ОБЯЗАТЕЛЬНО смените пароль перед деплоем!
WEB_USERNAME=admin
WEB_PASSWORD=changeme

# Ключ подписи сессионных cookie. Любая строка, рекомендуется 32+ символа.
# Если не задан — генерируется случайный при каждом старте (сессии сбрасываются при рестарте).
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
# WEB_SECRET_KEY=

# Порт веб-дашборда
# WEB_PORT=8080

# =============================================================================
# ОПЦИОНАЛЬНЫЕ ПЕРЕМЕННЫЕ
# =============================================================================

# Уровень логирования (DEBUG, INFO, WARNING, ERROR)
# По умолчанию: INFO
# LOG_LEVEL=INFO

# Rolling-release для yt-dlp (headless-safe)
# По умолчанию бот на старте делает `pip install --upgrade` для канала nightly
# Возможные значения: stable, nightly, master
# YTDLP_AUTO_UPDATE=true
# YTDLP_RELEASE_CHANNEL=nightly
# YTDLP_AUTO_UPDATE_TIMEOUT=240

# Локальный fallback через `python -m yt_dlp`, если встроенный API дал сбой
# YTDLP_CLI_FALLBACK=true
# YTDLP_CLI_TIMEOUT=900

# =============================================================================
# ИНСТРУКЦИИ ПО УСТАНОВКЕ
# =============================================================================

# Windows (Command Prompt):
# set TELEGRAM_TOKEN=your_token_here
# set GOKAPI_API_KEY=your_key_here
# set GOKAPI_BASE_URL=https://your-domain.com/api/

# Windows (PowerShell):
# $env:TELEGRAM_TOKEN="your_token_here"
# $env:GOKAPI_API_KEY="your_key_here"
# $env:GOKAPI_BASE_URL="https://your-domain.com/api/"

# Linux/Mac (Bash):
# export TELEGRAM_TOKEN="your_token_here"
# export GOKAPI_API_KEY="your_key_here"
# export GOKAPI_BASE_URL="https://your-domain.com/api/"

# Или создайте файл .secrets/.env (рекомендуется) или legacy .env в корне проекта и добавьте:
# TELEGRAM_TOKEN=your_token_here
# GOKAPI_API_KEY=your_key_here
# GOKAPI_BASE_URL=https://your-domain.com/api/

# Затем используйте python-dotenv для загрузки:
# pip install python-dotenv
# В начале main.py добавьте:
# from dotenv import load_dotenv
# load_dotenv()
